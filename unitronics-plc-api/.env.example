# Copy this file to .env and set your values. Do not commit .env (it's in .gitignore).
# Get a token: https://github.com/settings/tokens/new (scopes: repo, workflow)

GITHUB_TOKEN=

# Optional: PLC connection (defaults shown)
# PLC_HOST=127.0.0.1
# PLC_PORT=502
# PLC_UNIT_ID=1

# Optional: Azure Blob Storage (data is also appended here when set)
# Get connection string: Azure Portal → Storage account → Access keys → Connection string
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
# AZURE_CONTAINER_NAME=plc-data
# AZURE_BLOB_NAME=plc_collected.jsonl

# Snowflake: connect and load from Azure Blob (optional)
# SNOWFLAKE_ACCOUNT=xy12345 (or org-account)
# SNOWFLAKE_USER=myuser
# SNOWFLAKE_PASSWORD=mypassword
# SNOWFLAKE_WAREHOUSE=COMPUTE_WH
# SNOWFLAKE_DATABASE=PLC_DB
# SNOWFLAKE_SCHEMA=PUBLIC
# SNOWFLAKE_ROLE= (optional)
# For Azure stage (same container as above): storage account name + SAS token
# AZURE_STORAGE_ACCOUNT_NAME=mystorageaccount
# AZURE_SAS_TOKEN=?sv=2021-06-08&ss=... (from Azure Portal → container → Shared access signature)
