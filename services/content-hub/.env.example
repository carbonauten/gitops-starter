# Copy to .env for local docker compose and fill in values.
# Never commit .env to git.

# Public domain (must point to the server IP before HTTPS works)
DOMAIN=platform.example.com
ACME_EMAIL=admin@example.com

# PostgreSQL
POSTGRES_PASSWORD=change-me-long-random

# App secrets
SESSION_SECRET=change-me-long-random
ENTRA_MOCK_AUTH=false

# Microsoft Entra ID (M365 login)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Multichannel publishing (Sprint 4)
PUBLISH_MOCK_MODE=true
NOTION_API_KEY=
NOTION_DATABASE_ID=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
TEAMS_TEAM_ID=
TEAMS_CHANNEL_ID=
OUTLOOK_SENDER_ID=

# SharePoint / OneDrive file browser
FILES_BROWSE_MOCK_MODE=true
SHAREPOINT_SITE_URL=
SHAREPOINT_DRIVE_ID=
SHAREPOINT_DISPLAY_NAME=Firmendokumente

# Invite emails (Resend recommended on Railway)
RESEND_API_KEY=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=

# Docker image (set by CI on deploy)
CONTENT_HUB_IMAGE=ghcr.io/carbonauten/content-hub:latest
