# Copy to .env on the Hetzner server and fill in values.
# Never commit .env to git.

# Public domain (must point to the server IP before HTTPS works)
DOMAIN=platform.example.com
ACME_EMAIL=admin@example.com

# PostgreSQL
POSTGRES_PASSWORD=change-me-long-random

# App secrets
SESSION_SECRET=change-me-long-random
ENTRA_MOCK_AUTH=false

# Microsoft Entra ID (M365 login)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Docker image (set by CI on deploy)
CONTENT_HUB_IMAGE=ghcr.io/carbonauten/content-hub:latest
